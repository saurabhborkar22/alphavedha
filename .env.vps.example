# Copy to .env.vps and fill in all values before running docker compose

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=alphavedha
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=alphavedha
DATABASE_URL=postgresql://alphavedha:change_me_strong_password@postgres:5432/alphavedha

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@redis:6379/0

# ── App ───────────────────────────────────────────────────────
# Set to 0 for real predictions (requires trained models)
# Set to 1 for demo mode (no models needed, uses synthetic data)
ALPHAVEDHA_DEMO=1

# API key for UI login (choose any strong random string)
ALPHAVEDHA_API_KEY=change_me_api_key_min_32_chars

# ── Optional: News Sentiment ──────────────────────────────────
# Leave blank to skip news features
FINNHUB_API_KEY=
MARKETAUX_API_KEY=

# ─── Proof publishing (verifiable record) ───
# SSH URL of the private proofs repo; the publisher adds it as origin.
ALPHAVEDHA_PROOFS_REMOTE=git@github.com:saurabhborkar22/alphavedha-proofs.git
# Deploy key mounted read-only at /secrets by docker-compose.vps.yml.
GIT_SSH_COMMAND=ssh -i /secrets/proofs_deploy_key -o IdentitiesOnly=yes -o StrictHostKeyChecking=accept-new -o UserKnownHostsFile=/tmp/known_hosts
