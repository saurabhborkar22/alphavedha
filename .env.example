# AlphaVedha Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://alphavedha:alphavedha_dev@localhost:5435/alphavedha
REDIS_URL=redis://localhost:6379/0

# Data Providers (optional — free sources work without keys)
FINNHUB_API_KEY=
MARKETAUX_API_KEY=

# LLM Extraction (Phase 2 — Intel pipeline)
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
INTEL_LLM_BUDGET_USD=50

# Email Alerts (optional — SMTP for notifications)
ALERT_EMAIL_ENABLED=false
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_SENDER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_RECIPIENT=

# Telegram — outbound alerts via the execution-engine bot (BotFather token;
# chat IDs comma-separated, get yours from the bot's getUpdates after /start)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Telegram — live news watcher (user-account MTProto via Telethon).
# Create api_id/api_hash at https://my.telegram.org, then run once:
#   python -m alphavedha.intel.telegram_live login
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION=telegram_news
# Channels for both the 15-min preview collector and the live watcher
TELEGRAM_NEWS_CHANNELS=moneycontrolcom,ndtvprofitnews,cnbc_tv18

# Broker API (Phase 3 — automated trading, not needed for Phase 1)
# KITE_API_KEY=
# KITE_API_SECRET=
