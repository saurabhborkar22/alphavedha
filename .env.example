# AlphaVedha Environment Variables
# Copy this to .env and fill in your values

# Database
DATABASE_URL=postgresql://alphavedha:alphavedha_dev@localhost:5435/alphavedha
REDIS_URL=redis://localhost:6379/0

# Data Providers (optional — free sources work without keys)
FINNHUB_API_KEY=
MARKETAUX_API_KEY=

# LLM Extraction (Phase 2 — Intel pipeline)
GEMINI_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
INTEL_LLM_BUDGET_USD=50

# Email Alerts (optional — SMTP for notifications)
ALERT_EMAIL_ENABLED=false
ALERT_SMTP_HOST=smtp.gmail.com
ALERT_SMTP_PORT=587
ALERT_SMTP_SENDER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_RECIPIENT=

# Broker API (Phase 3 — automated trading, not needed for Phase 1)
# KITE_API_KEY=
# KITE_API_SECRET=
