# AlphaVedha Production Environment
# Copy to .env.prod and fill in real values

# PostgreSQL
POSTGRES_USER=alphavedha
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=alphavedha
DATABASE_URL=postgresql+asyncpg://alphavedha:CHANGE_ME_STRONG_PASSWORD@postgres:5432/alphavedha

# Redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@redis:6379/0

# API
ALPHAVEDHA_API_KEY=CHANGE_ME_API_KEY
ALPHAVEDHA_API_KEY_SECONDARY=
ALPHAVEDHA_ENV=production

# CORS (comma-separated origins, empty = disabled)
ALPHAVEDHA_CORS_ORIGINS=

# Database Pool Tuning
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Data Providers (optional)
FINNHUB_API_KEY=
MARKETAUX_API_KEY=
